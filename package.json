{
  "private": true,
  "workspaces": [
    "js/packages/*"
  ],
  "type": "module",
  "scripts": {
    "format": "prettier --write js package.json eslint.config.js",
    "format:check": "prettier --check js package.json eslint.config.js",
    "lint": "eslint js",
    "test": "node --test js/tests/*.test.js"
  },
  "engines": {
    "node": ">=20.19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.1"
  }
}
